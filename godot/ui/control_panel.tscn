[gd_scene load_steps=2 format=3 uid="uid://ccontrolpanel"]

[ext_resource type="Script" path="res://ui/control_panel.gd" id="1_script"]

[node name="ControlPanel" type="PanelContainer"]
script = ExtResource("1_script")

[node name="MarginContainer" type="MarginContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 6.0
offset_top = 6.0
offset_right = -6.0
offset_bottom = -6.0

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer"]

[node name="PlayPauseButton" type="Button" parent="MarginContainer/VBoxContainer"]
text = "Pause"

[node name="SpeedOption" type="OptionButton" parent="MarginContainer/VBoxContainer"]

[node name="SaveButton" type="Button" parent="MarginContainer/VBoxContainer"]
text = "Save"

[node name="LoadButton" type="Button" parent="MarginContainer/VBoxContainer"]
text = "Load"

[connection signal="pressed" from="MarginContainer/VBoxContainer/PlayPauseButton" to="." method="_on_play_pause_button_pressed"]
[connection signal="item_selected" from="MarginContainer/VBoxContainer/SpeedOption" to="." method="_on_speed_option_item_selected"]
[connection signal="pressed" from="MarginContainer/VBoxContainer/SaveButton" to="." method="_on_save_button_pressed"]
[connection signal="pressed" from="MarginContainer/VBoxContainer/LoadButton" to="." method="_on_load_button_pressed"]
